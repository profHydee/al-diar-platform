# ----------------------------------------------------------------------------
# Al-Diar Digital Experience Platform — Environment (placeholders)
# Copy to .env and fill in. All values below are non-functional placeholders.
# ----------------------------------------------------------------------------

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aldiar?schema=public"

# Auth.js
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Clover Payment Gateway (sandbox placeholders)
CLOVER_APP_ID="demo-clover-app-id"
CLOVER_APP_SECRET="demo-clover-app-secret"
CLOVER_MERCHANT_ID="demo-merchant-id"
CLOVER_ACCESS_TOKEN="demo-access-token"
CLOVER_ENVIRONMENT="sandbox"

# Cloudinary
CLOUDINARY_CLOUD_NAME="demo-cloud"
CLOUDINARY_API_KEY="demo-key"
CLOUDINARY_API_SECRET="demo-secret"

# Resend (email)
RESEND_API_KEY="re_demo_key"
RESEND_FROM_EMAIL="hello@aldiar.example"

# Public
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_GOOGLE_MAPS_KEY="demo-maps-key"
